{
  "name": "vocation-hub-scraper",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright-based scraper for Episcopal Church Vocation Hub",
  "scripts": {
    "scrape": "tsx src/index.ts",
    "scrape:dry": "tsx src/index.ts --dry-run",
    "discover": "tsx src/discover-ids.ts",
    "deep-scrape": "tsx src/deep-scrape.ts",
